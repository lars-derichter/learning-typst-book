// One set rule switches on automatic heading numbers. The "1." pattern
// numbers top-level headings 1, 2, ... and nests sub-headings as 1.1,
// 1.2, 2.1, and so on -- Typst counts them for you.
// Compile with:  typst compile main.typ out.pdf
#set page(width: 12cm, height: auto, margin: 1.5cm)

#set heading(numbering: "1.")

